{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "src/index.ts",
            "routePrefix": "/_/backend"
        }
    },
    "cleanUrls": true,
    "rewrites": [
        {
            "source": "/((?!_/).*)",
            "destination": "/index.html"
        }
    ]
}
